{
  "manifest_version": 3,
  "name": "DMM Work Capture Helper",
  "version": "0.1.0",
  "description": "DMM/FANZA同人の作品ページから定型情報を抽出し、レビュー用JSONへまとめます。",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "DMM作品を取り込む"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "現在開いている DMM/FANZA 作品ページを取り込む"
    }
  }
}
